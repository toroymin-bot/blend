{
  "name": "blend",
  "version": "1.0.0",
  "private": true,
  "blend": {
    "extractable_modules": [
      {
        "path": "src/modules/onboarding",
        "future_npm": "@ai4min/byok-onboarding",
        "tier": "S"
      },
      {
        "path": "src/stores/api-key-store",
        "future_npm": "@ai4min/api-key-store",
        "tier": "S"
      },
      {
        "path": "src/scripts/update-models",
        "future_npm": "@ai4min/model-registry",
        "tier": "S"
      },
      {
        "path": "src/design",
        "future_npm": "@ai4min/d1-tokens",
        "tier": "S"
      },
      {
        "path": "src/modules/chat",
        "future_npm": "@ai4min/chat-view",
        "tier": "A"
      },
      {
        "path": "src/modules/compare",
        "future_npm": "@ai4min/compare-view",
        "tier": "A"
      },
      {
        "path": "src/modules/billing",
        "future_npm": "@ai4min/billing-view",
        "tier": "A"
      },
      {
        "path": "src/modules/dashboard",
        "future_npm": "@ai4min/dashboard-view",
        "tier": "A"
      },
      {
        "path": "src/modules/cost-savings",
        "future_npm": "@ai4min/cost-savings-view",
        "tier": "A"
      },
      {
        "path": "src/modules/documents",
        "future_npm": "@ai4min/rag-documents",
        "tier": "A"
      },
      {
        "path": "src/lib/analytics.ts",
        "future_npm": "@ai4min/anonymous-analytics",
        "tier": "A"
      }
    ]
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "update-models": "tsx scripts/update-models.ts",
    "update-models:commit": "bash scripts/update-models.sh"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.66",
    "@ai-sdk/google": "^3.0.58",
    "@ai-sdk/openai": "^3.0.50",
    "@distube/ytdl-core": "^4.16.12",
    "@tosspayments/tosspayments-sdk": "^2.6.0",
    "@types/file-saver": "^2.0.7",
    "@vercel/analytics": "^2.0.1",
    "ai": "^6.0.146",
    "docx": "^9.6.1",
    "file-saver": "^2.0.5",
    "highlight.js": "^11.11.1",
    "html2pdf.js": "^0.14.0",
    "idb": "^8.0.3",
    "lucide-react": "^1.7.0",
    "marked": "^17.0.5",
    "markmap-lib": "^0.18.12",
    "markmap-view": "^0.18.12",
    "next": "16.2.2",
    "next-themes": "^0.4.6",
    "pdfjs-dist": "^5.6.205",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "uuid": "^13.0.0",
    "xlsx": "^0.18.5",
    "youtube-transcript": "^1.3.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vercel/node": "^5.7.11",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
