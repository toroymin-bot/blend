{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options",         "value": "DENY" },
        { "key": "X-Content-Type-Options",  "value": "nosniff" },
        { "key": "Referrer-Policy",         "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",      "value": "camera=(), microphone=(self), geolocation=(), payment=(self)" },
        { "key": "Strict-Transport-Security","value": "max-age=63072000; includeSubDomains; preload" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/ko",
      "destination": "/design1/ko",
      "permanent": true
    },
    {
      "source": "/en",
      "destination": "/design1/en",
      "permanent": true
    },
    {
      "source": "/ko/share",
      "destination": "/design1/ko/share",
      "permanent": true
    },
    {
      "source": "/en/share",
      "destination": "/design1/en/share",
      "permanent": true
    },
    {
      "source": "/ko/qatest",
      "destination": "/design1/ko/qatest",
      "permanent": true
    },
    {
      "source": "/en/qatest",
      "destination": "/design1/en/qatest",
      "permanent": true
    }
  ]
}
